{
  "uid": "nas-overview",
  "title": "NAS Overview",
  "tags": ["homelab", "nas", "node-exporter"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "nas",
        "label": "NAS",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(node_uname_info{service=\"nas-node-exporter\"}, instance)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "current": { "selected": false, "text": "All", "value": "$__all" }
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "CPU Usage",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{service=\"nas-node-exporter\",mode=\"idle\",instance=~\"$nas\"}[2m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Memory Usage",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes{service=\"nas-node-exporter\",instance=~\"$nas\"} / node_memory_MemTotal_bytes{service=\"nas-node-exporter\",instance=~\"$nas\"}))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Load (1m)",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_load1{service=\"nas-node-exporter\",instance=~\"$nas\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 4 },
              { "color": "red", "value": 8 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "CPU Usage Over Time",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{service=\"nas-node-exporter\",mode=\"idle\",instance=~\"$nas\"}[2m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Memory Usage Over Time",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{service=\"nas-node-exporter\",instance=~\"$nas\"} - node_memory_MemAvailable_bytes{service=\"nas-node-exporter\",instance=~\"$nas\"}",
          "legendFormat": "{{instance}} used",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemTotal_bytes{service=\"nas-node-exporter\",instance=~\"$nas\"}",
          "legendFormat": "{{instance}} total",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Network Traffic",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{service=\"nas-node-exporter\",instance=~\"$nas\",device!~\"lo|docker.*|veth.*|br-.*|cni.*|flannel.*\"}[2m]) * 8",
          "legendFormat": "{{instance}} {{device}} rx",
          "refId": "A"
        },
        {
          "expr": "-rate(node_network_transmit_bytes_total{service=\"nas-node-exporter\",instance=~\"$nas\",device!~\"lo|docker.*|veth.*|br-.*|cni.*|flannel.*\"}[2m]) * 8",
          "legendFormat": "{{instance}} {{device}} tx",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Disk I/O (bytes/s)",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{service=\"nas-node-exporter\",instance=~\"$nas\",device!~\"loop.*|dm-.*\"}[2m])",
          "legendFormat": "{{instance}} {{device}} read",
          "refId": "A"
        },
        {
          "expr": "-rate(node_disk_written_bytes_total{service=\"nas-node-exporter\",instance=~\"$nas\",device!~\"loop.*|dm-.*\"}[2m])",
          "legendFormat": "{{instance}} {{device}} write",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Filesystem Usage",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - ((node_filesystem_avail_bytes{service=\"nas-node-exporter\",instance=~\"$nas\",fstype!~\"tmpfs|devtmpfs|overlay|squashfs|ramfs|fuse.*\"} / node_filesystem_size_bytes{service=\"nas-node-exporter\",instance=~\"$nas\",fstype!~\"tmpfs|devtmpfs|overlay|squashfs|ramfs|fuse.*\"}) * 100)",
          "legendFormat": "{{instance}} {{mountpoint}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    }
  ]
}
